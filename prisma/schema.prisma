generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  name       String   @default("")
  email      String   @unique
  phone      String   @default("")
  password   String
  role       String   @default("customer")
  isVerified Boolean  @default(false)
  mfaEnabled Boolean  @default(false)
  mfaSecret  String?
  createdAt  DateTime @default(now())
}

model Product {
  id            String   @id @default(cuid())
  name          String
  brand         String
  category      String
  description   String?
  price         Int
  originalPrice Int?
  isNew         Boolean  @default(false)
  isBestSeller  Boolean  @default(false)
  stock         Int      @default(0)
  inStock       Boolean  @default(true)
  image         String
  skinType      String   @default("[]")
  ingredients   String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reviews       Review[]

  @@index([category])
  @@index([brand])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  userName  String
  rating    Int      @default(5)
  comment   String
  images    String   @default("[]")
  date      DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
}

model Order {
  id                String      @id
  customer          String
  email             String
  location          String?
  paymentMethod     String
  paymentStatus     String      @default("Pending Verification")
  paymentScreenshot String?
  status            String      @default("Pending")
  total             Int
  date              DateTime    @default(now())
  items             OrderItem[]

  @@index([email])
  @@index([status])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  name      String
  quantity  Int
  price     Int    @default(0)
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String
  type      String
  expires   DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
}
